# ══════════════════════════════════════════════════════
# MTVC API SERVER — Pi Environment Config
# Copy to .env and edit before starting the server
# ══════════════════════════════════════════════════════

PORT=8080

# ── VICTRON ─────────────────────────────────────────
VEDIRECT_PATH=/dev/ttyUSB0        # SmartShunt (VE.Direct USB)
MK3_PATH=/dev/ttyUSB1             # Multiplus 2 (MK3-USB interface)

# ── RELAY BOARD TYPE ─────────────────────────────────
# Most relay boards (SainSmart, YwRobot, etc.) are active-LOW,
# meaning GPIO LOW = relay ON.  Set to true only if your board
# is active-high (GPIO HIGH = relay ON).
RELAY_ACTIVE_HIGH=false

# ── LIGHTS → GPIO RELAY PINS ─────────────────────────
# Map each light ID to the GPIO BCM pin driving that relay.
# Leave a line commented out to skip GPIO for that light.
#
#  Light ID | Default Name   | Set to your relay GPIO pin
#  ---------|----------------|---------------------------
LIGHT_0_GPIO=17    # Cab
LIGHT_1_GPIO=27    # Load Bay
LIGHT_2_GPIO=22    # Work
LIGHT_3_GPIO=23    # Step
LIGHT_4_GPIO=24    # Exterior
LIGHT_5_GPIO=25    # Tools
LIGHT_6_GPIO=5     # Rear
LIGHT_7_GPIO=6     # Emergency

# ── FANS → GPIO PWM PINS ─────────────────────────────
# Must be hardware-PWM capable pins on Pi 5: 12, 13, 18, 19
FAN_0_GPIO=18    # Cabinet fan
FAN_1_GPIO=19    # Exhaust fan
FAN_2_GPIO=12    # Aux fan
FAN_MIN_TEMP=30
FAN_MAX_TEMP=60
FAN_MIN_SPEED=20

# ── TEMPERATURE SENSOR ───────────────────────────────
DS18B20_BASE=/sys/bus/w1/devices
